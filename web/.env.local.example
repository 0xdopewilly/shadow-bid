# Copy these into Vercel → Project → Settings → Environment Variables (Production / Preview).
# No local `.env.local` is required if you only deploy from GitHub.

# Canonical site URL (used for absolute links where needed).
NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app

# Shared RPC — every visitor should hit the same cluster so listings match.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# REQUIRED on Devnet: must equal `arcium deploy -o …` (456 here). If this is 0 on a hosted RPC,
# sealed bids/reveal talk to wrong MXC PDAs — `bid_count` stays frozen at 0.
# Use 0 only with local `arcium localnet` / Docker.
NEXT_PUBLIC_ARCIUM_CLUSTER_OFFSET=456

# Must match `web/lib/idl/shadow_bid.json` after you deploy a new program build.
NEXT_PUBLIC_SHADOW_BID_PROGRAM_ID=EvyVpkAWdKABJAZZ73YkMwGiVS3QJMEJ7vHvKh6FYuBt
