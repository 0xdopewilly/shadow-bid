# Required for hosted deployments (Vercel, etc.)
NEXT_PUBLIC_SITE_URL=https://your-deployment.example.com

# Shared RPC — all browsers should use the same URL so listings stay in sync.
# Solana Devnet (default if unset):
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Must match the Arcium cluster offset used when deploying this program (see Anchor / Arcium tooling).
NEXT_PUBLIC_ARCIUM_CLUSTER_OFFSET=0

# Deploy your build of shadow_bid and paste the program id here (must match web/lib/idl/shadow_bid.json).
NEXT_PUBLIC_SHADOW_BID_PROGRAM_ID=EvyVpkAWdKABJAZZ73YkMwGiVS3QJMEJ7vHvKh6FYuBt

# Local development against a validator on this machine — overrides devnet default:
# NEXT_PUBLIC_SOLANA_RPC_URL=http://127.0.0.1:8899
